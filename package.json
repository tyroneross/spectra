{
  "name": "@tyroneross/spectra",
  "version": "0.3.0",
  "description": "AI-native UI automation across web, macOS, iOS, and watchOS. Claude Code + Codex plugin + MCP server + standalone CLI.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "spectra": "./bin/spectra"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "bin/",
    "scripts/postinstall.sh",
    ".claude-plugin/",
    ".codex-plugin/",
    "commands/",
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:native": "swiftc native/swift/Types.swift native/swift/main.swift native/swift/AppTarget.swift native/swift/AXBridge.swift native/swift/SimBridge.swift native/swift/MediaCapture.swift -framework Foundation -framework ApplicationServices -framework AppKit -framework CoreGraphics -o $HOME/.spectra/bin/spectra-native",
    "build:test-app": "swiftc native/swift/TestApp/TestApp.swift -framework SwiftUI -framework AppKit -o $HOME/.spectra/bin/spectra-test-app",
    "daemon": "node dist/cli/index.js daemon",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "serve": "cd web-ui && npm run dev -- -p 4300",
    "build:dmg": "bash scripts/build-and-refresh.sh",
    "build:dmg:adhoc": "bash scripts/build-and-refresh.sh --adhoc",
    "postinstall": "bash scripts/postinstall.sh || true"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.20.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1",
    "yaml": "^2.6.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Tyrone Ross"
  },
  "homepage": "https://github.com/tyroneross/spectra",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tyroneross/spectra.git"
  },
  "bugs": {
    "url": "https://github.com/tyroneross/spectra/issues"
  },
  "keywords": [
    "screenshots",
    "video-capture",
    "content-creation",
    "marketing",
    "demo-recording",
    "accessibility",
    "ui-automation",
    "mcp",
    "claude-code",
    "codex",
    "plugin"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
