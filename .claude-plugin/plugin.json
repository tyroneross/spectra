{
  "name": "spectra",
  "description": "Capture screenshots, videos, and polished demo clips — spotlight focus, lower-third captions, and a tagged library — across web, macOS, and iOS",
  "author": {
    "name": "Tyrone Ross"
  },
  "license": "Apache-2.0",
  "keywords": [
    "screenshots",
    "video-capture",
    "content-creation",
    "marketing",
    "demo-recording",
    "accessibility"
  ],
  "mcpServers": {
    "spectra": {
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/dist/mcp/server.js"
      ],
      "tools": [
        "spectra_connect",
        "spectra_snapshot",
        "spectra_act",
        "spectra_step",
        "spectra_capture",
        "spectra_session",
        "spectra_analyze",
        "spectra_discover",
        "spectra_walkthrough",
        "spectra_record",
        "spectra_replay",
        "spectra_library",
        "spectra_demo",
        "spectra_computer_use",
        "spectra_llm_step"
      ]
    }
  }
}
